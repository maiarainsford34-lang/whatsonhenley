<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Montserrat:wght@300;400;500&display=swap" rel="stylesheet">
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { background: #08090d; margin: 0; padding: 0; overflow-x: hidden; }

.hero {
  position: relative; width: 100%;
  height: 100vh; min-height: 600px;
  overflow: hidden; background: #08090d;
}
.slide {
  position: absolute; inset: 0; opacity: 0;
  transition: opacity 1s ease;
}
.slide.active { opacity: 1; }
.slide img {
  width: 100%; height: 100%; object-fit: cover;
  filter: brightness(0.82) contrast(1.05);
  animation: kenburns 4s ease-out forwards;
}
@keyframes kenburns {
  from { transform: scale(1.0); }
  to   { transform: scale(1.06); }
}
.hero-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to bottom,
    rgba(8,9,13,0.25) 0%, rgba(8,9,13,0.0) 30%,
    rgba(8,9,13,0.0) 50%, rgba(8,9,13,0.6) 75%,
    rgba(8,9,13,0.95) 100%);
  z-index: 5;
}
.hero-content {
  position: absolute; top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  z-index: 10; text-align: center;
  width: 90vw; max-width: 860px;
  animation: fadeUp 1.4s ease 0.4s both;
}
@keyframes fadeUp {
  from { opacity: 0; transform: translate(-50%, calc(-50% + 24px)); }
  to   { opacity: 1; transform: translate(-50%, -50%); }
}
.eyebrow {
  font-family: 'Montserrat', sans-serif; font-size: 10px;
  font-weight: 500; letter-spacing: 0.45em; text-transform: uppercase;
  color: #d4a853; margin-bottom: 10px;
}
.title-the {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(22px, 3.5vw, 46px);
  font-weight: 300; font-style: italic;
  color: #d4a853; letter-spacing: 0.1em; line-height: 1; margin-bottom: 2px;
}
.title-main {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(52px, 8vw, 96px);
  line-height: 0.9; color: #ffffff; letter-spacing: 0.06em;
}
.title-sub {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(18px, 3.2vw, 38px);
  font-weight: 300; font-style: italic;
  color: #d4a853; letter-spacing: 0.18em; margin-bottom: 14px;
}
.divider {
  display: flex; align-items: center; justify-content: center;
  gap: 14px; margin: 12px auto 16px; width: 240px;
}
.divider-line { flex: 1; height: 1px; background: rgba(212,168,83,0.45); }
.divider-diamond { width: 6px; height: 6px; background: #d4a853; transform: rotate(45deg); }
.tagline {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(14px, 2vw, 19px);
  font-weight: 300; font-style: italic;
  color: rgba(255,255,255,0.7); letter-spacing: 0.08em; margin-bottom: 6px;
}
.date-line {
  font-family: 'Montserrat', sans-serif; font-size: 10px;
  font-weight: 500; letter-spacing: 0.35em; text-transform: uppercase;
  color: rgba(255,255,255,0.45);
}
.artist-block {
  position: absolute; bottom: 52px; left: 44px;
  z-index: 10; opacity: 0; transition: opacity 0.8s ease;
}
.artist-block.active { opacity: 1; }
.artist-category {
  font-family: 'Montserrat', sans-serif; font-size: 9px;
  font-weight: 500; letter-spacing: 0.35em; text-transform: uppercase;
  color: #d4a853; margin-bottom: 5px;
}
.artist-name {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(22px, 3vw, 36px);
  font-weight: 400; color: #ffffff; line-height: 1.1; margin-bottom: 4px;
}
.artist-detail {
  font-family: 'Cormorant Garamond', serif;
  font-size: 14px; font-style: italic;
  color: rgba(255,255,255,0.55); letter-spacing: 0.03em;
}
.ticket-link {
  display: inline-block;
  margin-top: 10px;
  padding: 8px 20px;
  background: #b8924a;
  color: #0e1012;
  font-family: 'Montserrat', sans-serif;
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  text-decoration: none;
  pointer-events: all;
}
.ticket-link:hover { background: #d4aa6a; }
.dots {
  position: absolute; bottom: 24px; left: 50%;
  transform: translateX(-50%); z-index: 10;
  display: flex; gap: 8px;
}
.dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: rgba(255,255,255,0.25);
  transition: background 0.4s, transform 0.4s;
  cursor: pointer;
}
.dot.active { background: #d4a853; transform: scale(1.4); }

/* ── MOBILE ── */
@media (max-width: 600px) {
  .hero { min-height: 100svh; }
  .hero-content { width: 92vw; }
  .title-the { font-size: 20px; }
  .title-main { font-size: 56px; }
  .title-sub { font-size: 20px; }
  .tagline { font-size: 13px; }
  .date-line { font-size: 8px; letter-spacing: 0.2em; }
  .eyebrow { font-size: 8px; letter-spacing: 0.3em; }
  .artist-block { bottom: 48px; left: 20px; right: 20px; }
  .artist-name { font-size: 22px; }
  .artist-detail { font-size: 12px; }
  .artist-category { font-size: 8px; }
  .divider { width: 180px; }
}
</style>
</head>
<body>
<div class="hero" id="hero">
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <div class="eyebrow">Henley-on-Thames</div>
    <div class="title-the">The</div>
    <div class="title-main">HENLEY JAZZ</div>
    <div class="title-sub">Festival</div>
    <div class="divider">
      <div class="divider-line"></div>
      <div class="divider-diamond"></div>
      <div class="divider-line"></div>
    </div>
    <div class="tagline">Three nights of world-class jazz on the Thames</div>
    <div class="date-line">25 – 27 September 2026 &nbsp;·&nbsp; Henley-on-Thames</div>
  </div>
  <div id="slides"></div>
  <div id="artists"></div>
  <div class="dots" id="dots"></div>
</div>

<script>
const IMAGES = {
  buena: "data:image/jpeg;base64,",
  joe_stilgoe: "data:image/jpeg;base64,",
  liane: "data:image/png;base64,",
  bigband: "data:image/jpeg;base64,",
  joe_webb: "data:image/png;base64,",
  adrian: "data:image/png;base64,",
  enrico: "data:image/png;base64,",
  clare: "data:image/png;base64,",
  sentimental: "data:image/jpeg;base64,",
};



// ══════════════════════════════════════════════════
// ADD NEW GIGS HERE — one object per slide
// Fields: img, pos, category, name, detail
// ══════════════════════════════════════════════════
const GIGS = [
  { img: 'clare',       pos: 'center center', category: 'KENTON THEATRE',        name: 'Clare Teal',               detail: 'Friday 25 Sept · The Kenton Theatre',    ticket: '' },
  { img: 'buena',       pos: 'center center', category: 'HENLEY TOWN HALL',      name: "A Night in Havana",        detail: 'Friday 25 Sept · Henley Town Hall',       ticket: 'https://www.ticketsource.co.uk/the-henley-jazz-festival-limited/the-henley-jazz-festival-presents-buena-bristol-social-club/2026-09-25/20:00/t-lddmnnl' },
  { img: 'joe_stilgoe', pos: 'center center', category: 'KENTON THEATRE',        name: 'Joe Stilgoe',              detail: 'Saturday 26 Sept · The Kenton Theatre',   ticket: '' },
  { img: 'liane',       pos: 'center top',    category: "PURDY'S POP UP",        name: 'Liane Carroll',            detail: "Saturday 26 Sept · Purdy's Pop Up",        ticket: 'https://www.ticketsource.co.uk/the-henley-jazz-festival-limited/the-henley-jazz-festival-presents-liane-carroll/2026-09-26/20:00/t-yzzmrxa' },
  { img: 'bigband',     pos: 'center center', category: 'HENLEY TOWN HALL',      name: 'The Big Band Swing Dance', detail: 'Saturday 26 Sept · Henley Town Hall',      ticket: 'https://www.ticketsource.co.uk/the-henley-jazz-festival-limited/the-henley-jazz-festival-presents-the-big-band-swing-dance/2026-09-26/20:00/t-lddmndl' },
  { img: 'joe_webb',    pos: 'center top',    category: "PURDY'S POP UP",        name: 'Joe Webb Trio',            detail: "Friday 25 Sept · Purdy's Pop Up",          ticket: 'https://www.ticketsource.co.uk/the-henley-jazz-festival-limited/the-henley-jazz-festival-presents-the-joe-webb-trio-at-purdys-pop-up-jazz-club/2026-09-25/20:00/t-zoojerd' },
  { img: 'adrian',      pos: 'center center', category: 'NEW ORLEANS RIVERBOAT', name: 'Riverboat Shuffle',        detail: 'Saturday 26 Sept · The New Orleans',      ticket: 'https://www.ticketsource.co.uk/the-henley-jazz-festival-limited/the-henley-jazz-festival-presents-new-orleans-jazz-cruise-feat-adrian-cox-quartet/2026-09-26/15:00/t-mjjapjr' },
  { img: 'enrico',      pos: 'center center', category: 'NEW ORLEANS RIVERBOAT', name: 'A Salute to Satchmo',      detail: 'Sunday 27 Sept · The New Orleans',        ticket: 'https://www.ticketsource.co.uk/the-henley-jazz-festival-limited/the-henley-jazz-festival-presents-new-orleans-jazz-cruise-feat-enrico-tomasso/2026-09-27/15:00/t-kddlgon' },
  { img: 'sentimental', pos: 'center center', category: 'KENTON THEATRE',        name: 'Sentimental Journey',      detail: 'Sunday 27 Sept · The Kenton Theatre',     ticket: '' },
];


// ── BUILD SLIDES FROM GIGS DATA ──────────────────
const hero     = document.getElementById('hero');
const slidesEl = document.getElementById('slides');
const artistsEl= document.getElementById('artists');
const dotsEl   = document.getElementById('dots');
let current = 0;
let timer;

GIGS.forEach((g, i) => {
  // Slide
  const slide = document.createElement('div');
  slide.className = 'slide' + (i === 0 ? ' active' : '');
  const img = document.createElement('img');
  img.src = IMAGES[g.img];
  img.style.objectPosition = g.pos;
  slide.appendChild(img);
  slidesEl.appendChild(slide);

  // Artist block
  const block = document.createElement('div');
  block.className = 'artist-block' + (i === 0 ? ' active' : '');
  block.innerHTML = `
    <div class="artist-category">${g.category}</div>
    <div class="artist-name">${g.name}</div>
    <div class="artist-detail">${g.detail}</div>`;
  artistsEl.appendChild(block);

  // Dot
  const dot = document.createElement('div');
  dot.className = 'dot' + (i === 0 ? ' active' : '');
  dot.addEventListener('click', () => goTo(i));
  dotsEl.appendChild(dot);
});

function goTo(n) {
  const slides  = slidesEl.querySelectorAll('.slide');
  const artists = artistsEl.querySelectorAll('.artist-block');
  const dots    = dotsEl.querySelectorAll('.dot');
  slides[current].classList.remove('active');
  artists[current].classList.remove('active');
  dots[current].classList.remove('active');
  current = n;
  slides[current].classList.add('active');
  artists[current].classList.add('active');
  dots[current].classList.add('active');
  // Restart Ken Burns
  const img = slides[current].querySelector('img');
  img.style.animation = 'none';
  img.offsetHeight; // reflow
  img.style.animation = 'kenburns 4s ease-out forwards';
  clearInterval(timer);
  timer = setInterval(next, 4000);
}

function next() {
  goTo((current + 1) % GIGS.length);
}

timer = setInterval(next, 4000);
</script>
</body>
</html>
